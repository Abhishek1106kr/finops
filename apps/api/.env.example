PORT=4000
HOST=0.0.0.0
# Ports 5435/6380 (not 5432/6379) — this repo's docker-compose remaps them
# to avoid colliding with other local Postgres/Redis instances. Adjust if
# your machine is clear on the defaults.
DATABASE_URL="postgresql://pazypro:pazypro@localhost:5435/pazypro?schema=public"
REDIS_URL="redis://localhost:6380"
LOG_LEVEL=info

# PazyPay (our own payment gateway) — HMAC secret used to sign/verify
# settlement webhooks. Generate a real secret per environment; never reuse
# this placeholder outside local dev.
PAZYPAY_WEBHOOK_SECRET="dev-local-pazypay-secret-change-me"

# Finance Brain AI Copilot — required to enable POST /api/v1/ai/chat.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Socket.IO CORS origin for the /realtime namespace (the Nuxt dev server URL)
CORS_ORIGIN="http://localhost:3000"
